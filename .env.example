APP_NAME="My POS App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Branding (digunakan di config/axiom.php)
APP_SLOGAN="Modern POS & Order Management"
APP_TAGLINE="Point of Sale & Order Management System"
APP_LOGO_TEXT="POS"

# Commerce
APP_CURRENCY=IDR
APP_CURRENCY_SYMBOL=Rp

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database – pilih salah satu
# SQLite (development cepat, tidak perlu server):
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL / MariaDB (production):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=pos_db
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
